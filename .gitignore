# Xcode
# Note: project.pbxproj is generated from project.yml via XcodeGen
# Run `xcodegen generate` after cloning to create the Xcode project
*.xcodeproj/*
!*.xcodeproj/xcshareddata/
!*.xcworkspace/contents.xcworkspacedata
*.xcworkspace/*
!*.xcworkspace/xcshareddata/
# Track the SwiftPM pin file inside the generated project so dependency
# resolution is reproducible across machines and CI. Each parent level must
# be re-included because an excluded directory cannot have tracked children.
!*.xcodeproj/project.xcworkspace/
*.xcodeproj/project.xcworkspace/*
!*.xcodeproj/project.xcworkspace/xcshareddata/
*.xcodeproj/project.xcworkspace/xcshareddata/*
!*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/
!*.xcodeproj/project.xcworkspace/xcshareddata/swiftpm/Package.resolved
xcuserdata/
DerivedData/
build/
*.moved-aside
*.xccheckout
*.xcscmblueprint

# Swift Package Manager
.build/
.swiftpm/

# CocoaPods
Pods/

# Carthage
Carthage/Build/

# fastlane
fastlane/report.xml
fastlane/Preview.html
fastlane/screenshots/**/*.png
fastlane/test_output

# Code coverage
*.gcda
*.gcno
*.profraw
.coverage
htmlcov/

# Xcode test results
*.xcresult
*.xcresult/

# macOS
.DS_Store
.AppleDouble
.LSOverride
.Spotlight-V100
.Trashes

# Environment
.env
*.env

# Test recordings
Tests/Recordings/
*.wav
*.m4a

# Logs
*.log

# ML Models (too large for git)
# Use explicit path to avoid matching Swift code directories like Routing/Models/
/models/
*.mlmodel
*.mlpackage
*.safetensors
*.onnx
*.pt
*.pth
*.gguf

# llama.cpp XCFramework (large binary, download separately)
llama.xcframework/
llama-xcframework.tar.gz

# llama.cpp source clones (used for building, not tracked)
llama.cpp/
tools/llama.cpp/

# Claude draft files
.claude/draft-commit.md
.claude/*.lock

# Archive files in project root
/*.zip
/*.tar.gz
